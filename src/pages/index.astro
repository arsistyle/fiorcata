---
import Canvas from "../components/canvas.astro";
import "../styles/global.css";
import { Font } from "astro:assets";
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Fiorcata – Art that whispers the soul of Chilean nature</title>
    <meta
      name="description"
      content="Original watercolor and botanical illustrations inspired by Chile's native flora, epic landscapes and gentle wildlife. Premium canvas & art prints, shipped worldwide."
    />
    <meta
      property="og:title"
      content="Fiorcata – Art that whispers the soul of Chilean nature"
    />
    <meta
      property="og:description"
      content="Original watercolor and botanical illustrations inspired by Chile's native flora, epic landscapes and gentle wildlife. Premium canvas & art prints, shipped worldwide."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://fiorcata.com/" />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- meta og image -->
    <meta
      property="og:image"
      content="https://pub-7c20c4f95be84fcfa35c2ca966f8fb0d.r2.dev/fiorcata/img/og-image.png"
    />
    <Font cssVariable="--font-lora" preload />
    <Font cssVariable="--font-playfair-display" preload />
  </head>

  <body
    class="font-body bg-forest-950 text-cream-300 min-h-screen overflow-x-hidden font-lora"
  >
    <!-- ── Header ── -->
    <header
      class="flex items-center justify-between px-8 py-6 md:px-12 animate-header-in"
    >
      <a href="/" aria-label="Fiorcata Home" class="flex items-center">
        <img src="/logo.svg" alt="Fiorcata" class="h-8 md:h-12 w-auto" fetchpriority="high" />
      </a>
      <nav aria-label="Social links" class="flex items-center gap-5">
        <!-- Pinterest -->
        <a
          href="https://pinterest.com/fiorcata"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Pinterest"
          class="text-sage-500 hover:text-cream-300 transition-colors duration-300 flex items-center"
        >
          <svg
            class="w-[19px] h-[19px]"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"
            ></path>
          </svg>
        </a>

        <!-- Instagram -->
        <a
          href="https://instagram.com/fiorcata"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="text-sage-500 hover:text-cream-300 transition-colors duration-300 flex items-center"
        >
          <svg
            class="w-[19px] h-[19px]"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
            ></path>
          </svg>
        </a>

        <!-- Facebook -->
        <a
          href="https://facebook.com/fiorcata"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="text-sage-500 hover:text-cream-300 transition-colors duration-300 flex items-center"
        >
          <svg
            class="w-[19px] h-[19px]"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 6.032 4.388 11.02 10.125 11.927v-8.437H7.078v-3.49h3.047V9.43c0-3.007 1.793-4.669 4.533-4.669 1.312 0 2.686.234 2.686.234v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796v8.437C19.612 23.093 24 18.105 24 12.073z"
            ></path>
          </svg>
        </a>
      </nav>
    </header>

    <main id="main-content">
    <!-- ── Hero ── -->
    <section
      class="flex flex-col items-center justify-center text-center px-6 pt-16 pb-24 md:pt-20 md:pb-28"
    >
      <h1
        class="font-heading text-[clamp(2.8rem,5.5vw,8rem)] font-normal leading-[1.14] tracking-[0.01em] text-cream-300 max-w-7xl mb-6
                 animate-headline-in [animation-delay:0.2s]"
      >
        Art that whispers the soul of Chilean nature
      </h1>

      <p
        class="font-body text-[clamp(0.875rem,1.4vw,1.4rem)] leading-[1.78] text-sage-500 max-w-2xl mb-11
                animate-body-up [animation-delay:0.5s]"
      >
        Original watercolor and botanical illustrations inspired by Chile's
        native flora, epic landscapes and gentle wildlife. Premium canvas &amp;
        art prints, shipped worldwide.
      </p>

      <a
        href="https://etsy.com/shop/fiorcata"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3
                bg-terracotta-600 text-cream-100
                px-8 py-[0.875rem]
                font-body text-[0.79rem] font-medium tracking-[0.14em]
                no-underline rounded-[2px]
                transition-colors duration-300
                hover:bg-terracotta-500
                animate-body-up [animation-delay:0.75s]"
      >
        BUY CANVAS ON ETSY
        <svg
          class="w-4 h-4 shrink-0 transition-transform duration-300 group-hover:translate-x-1"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </section>

    <!-- ── Gallery ── -->
    <section class="pb-28 overflow-x-clip animate-body-up">
      <div class="container mx-auto px-4">
        <div class="flex flex-col gap-4">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
            <Canvas
              scaleStart={1.2}
              scaleEnd={1}
              translateYStart={"-15%"}
              translateYEnd={0}
              translateXStart={"-25%"}
              translateXEnd={0}
              orientation="portrait"
              src="https://pub-7c20c4f95be84fcfa35c2ca966f8fb0d.r2.dev/fiorcata/img/canvas-01.webp"
              alt="Botanical watercolor illustration"
              class="col-span-1 [animation-range:entry_0%_cover_55%] origin-bottom-right"
            />
            <Canvas
              scaleStart={1.3}
              scaleEnd={1}
              translateYStart={"-75%"}
              translateYEnd={0}
              translateXStart={0}
              translateXEnd={0}
              orientation="landscape"
              src="https://pub-7c20c4f95be84fcfa35c2ca966f8fb0d.r2.dev/fiorcata/img/canvas-02.webp"
              alt="Botanical watercolor illustration"
              class="col-span-1 [animation-range:entry_0%_cover_40%] origin-bottom-center"
            />
            <Canvas
              scaleStart={1.2}
              scaleEnd={1}
              translateYStart={"-15%"}
              translateYEnd={0}
              translateXStart={"25%"}
              translateXEnd={0}
              orientation="portrait"
              src="https://pub-7c20c4f95be84fcfa35c2ca966f8fb0d.r2.dev/fiorcata/img/canvas-03.webp"
              alt="Botanical watercolor illustration"
              class="col-span-1 [animation-range:entry_0%_cover_55%] origin-bottom-left"
            />
          </div>
          <div
            class="grid grid-cols-1 md:grid-cols-6 lg:grid-cols-12 gap-4 items-start"
          >
            <div
              class="col-span-1 md:col-span-2 lg:col-span-3 flex flex-col gap-4"
            >
              <Canvas
                scaleStart={1}
                scaleEnd={1}
                translateYStart={0}
                translateYEnd={0}
                translateXStart={"-25%"}
                translateXEnd={0}
                orientation="landscape"
                src="https://pub-7c20c4f95be84fcfa35c2ca966f8fb0d.r2.dev/fiorcata/img/canvas-04.webp"
                alt="Botanical watercolor illustration"
                class="col-span-1 [animation-range:entry_0%_cover_25%] origin-top-right"
              />
              <Canvas
                scaleStart={1}
                scaleEnd={1}
                translateYStart={"15%"}
                translateYEnd={0}
                translateXStart={"-25%"}
                translateXEnd={0}
                orientation="landscape"
                src="https://pub-7c20c4f95be84fcfa35c2ca966f8fb0d.r2.dev/fiorcata/img/canvas-05.webp"
                alt="Botanical watercolor illustration"
                class="col-span-1 [animation-range:entry_0%_cover_25%] origin-top-left"
              />
            </div>
            <div class="col-span-1 md:col-span-2 lg:col-span-3">
              <Canvas
                scaleStart={1}
                scaleEnd={1}
                translateYStart={"15%"}
                translateYEnd={0}
                translateXStart={0}
                translateXEnd={0}
                orientation="portrait"
                src="https://pub-7c20c4f95be84fcfa35c2ca966f8fb0d.r2.dev/fiorcata/img/canvas-06.webp"
                alt="Botanical watercolor illustration"
                class="[animation-range:entry_0%_cover_30%] origin-top-center"
              />
            </div>
            <div class="col-span-1 md:col-span-2">
              <Canvas
                scaleStart={1}
                scaleEnd={1}
                translateYStart={"75%"}
                translateYEnd={0}
                translateXStart={0}
                translateXEnd={0}
                orientation="portrait"
                src="https://pub-7c20c4f95be84fcfa35c2ca966f8fb0d.r2.dev/fiorcata/img/canvas-07.webp"
                alt="Botanical watercolor illustration"
                class="[animation-range:entry_0%_cover_30%] origin-top-center"
              />
            </div>
            <div
              class="col-span-1 md:col-span-2 lg:col-span-4 flex flex-col gap-4"
            >
              <Canvas
                scaleStart={1}
                scaleEnd={1}
                translateYStart={0}
                translateYEnd={0}
                translateXStart={"45%"}
                translateXEnd={0}
                orientation="landscape"
                src="https://pub-7c20c4f95be84fcfa35c2ca966f8fb0d.r2.dev/fiorcata/img/canvas-08.webp"
                alt="Botanical watercolor illustration"
                class="col-span-1 [animation-range:entry_0%_cover_25%] origin-top-left"
              />
              <div class="grid grid-cols-1 md:grid-cols-2">
                <div class="col-span-1 flex flex-col gap-4">
                  <Canvas
                    scaleStart={1}
                    scaleEnd={1}
                    translateYStart={0}
                    translateYEnd={0}
                    translateXStart={"15%"}
                    translateXEnd={0}
                    orientation="landscape"
                    src="https://pub-7c20c4f95be84fcfa35c2ca966f8fb0d.r2.dev/fiorcata/img/canvas-09.webp"
                    alt="Botanical watercolor illustration"
                    class="col-span-1 [animation-range:entry_0%_cover_25%] origin-top-left"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="flex justify-center pt-32 px-4">
          <a
            href="https://etsy.com/shop/fiorcata"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3
                bg-terracotta-600 text-cream-100
                px-8 py-[0.875rem]
                font-body text-[0.79rem] font-medium tracking-[0.14em]
                no-underline rounded-[2px]
                transition-colors duration-300
                hover:bg-terracotta-500
                animate-body-up [animation-delay:0.75s]"
          >
            BUY CANVAS ON ETSY
            <svg
              class="w-4 h-4 shrink-0 transition-transform duration-300 group-hover:translate-x-1"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </section>
    </main><!-- end #main-content -->
  </body><!-- ── Footer ── -->
  <footer
    class="flex flex-col items-center text-center py-12 pb-16 gap-[0.6rem]"
  >
    <img src="/logo.svg" alt="Fiorcata" class="h-6 md:h-10 w-auto mb-6" />
    <p class="font-body text-[0.75rem] tracking-[0.05em] text-sage-400">
      &copy; 2026 Fiorcata. Inspired by the Wonders of Chile.
    </p>
  </footer>
</html>
